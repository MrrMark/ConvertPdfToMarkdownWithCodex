          "title": "Line Merge Count",
          "type": "integer"
        },
        "low_conf_token_ratio": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Low Conf Token Ratio"
        },
        "ocr_attempted": {
          "default": false,
          "title": "Ocr Attempted",
          "type": "boolean"
        },
        "ocr_confidence_mean": {
