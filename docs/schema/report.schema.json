      "enum": [
        "success",
        "partial_success",
        "failed"
      ],
      "title": "ConversionStatus",
      "type": "string"
    },
    "PageResult": {
      "properties": {
        "char_count": {
          "default": 0,
          "title": "Char Count",
          "type": "integer"
        },
        "column_count_estimate": {
