{
  "$defs": {
    "BatchDocumentFiles": {
      "properties": {
        "cross_refs_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cross Refs Rag"
        },
        "domain_units_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Domain Units Rag"
        },
        "figures_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Figures Rag"
        },
        "manifest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Manifest"
        },
        "markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Markdown"
        },
        "rag_tables_markdown": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rag Tables Markdown"
        },
        "report": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Report"
        },
        "requirement_traceability_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requirement Traceability Rag"
        },
        "requirements_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requirements Rag"
        },
        "retrieval_chunks_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retrieval Chunks Rag"
        },
        "sanitized_report": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sanitized Report"
        },
        "semantic_units_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Semantic Units Rag"
        },
        "tables_rag_jsonl": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tables Rag Jsonl"
        },
        "technical_tables_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Technical Tables Rag"
        },
        "text_blocks_rag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text Blocks Rag"
        }
      },
      "title": "BatchDocumentFiles",
      "type": "object"
    },
    "BatchDocumentResult": {
      "properties": {
        "duration_ms": {
          "default": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "exit_code": {
          "title": "Exit Code",
          "type": "integer"
        },
        "files": {
          "$ref": "#/$defs/BatchDocumentFiles"
        },
        "finished_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
        },
        "image_count": {
          "default": 0,
          "title": "Image Count",
          "type": "integer"
        },
        "input_pdf": {
          "title": "Input Pdf",
          "type": "string"
        },
        "output_dir": {
          "title": "Output Dir",
          "type": "string"
        },
        "skipped": {
          "default": false,
          "title": "Skipped",
          "type": "boolean"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "status": {
          "title": "Status",
          "type": "string"
        },
        "table_count": {
          "default": 0,
          "title": "Table Count",
          "type": "integer"
        },
        "used_ocr": {
          "default": false,
          "title": "Used Ocr",
          "type": "boolean"
        },
        "warning_count": {
          "default": 0,
          "title": "Warning Count",
          "type": "integer"
        }
      },
      "required": [
        "input_pdf",
        "status",
        "exit_code",
        "output_dir"
      ],
      "title": "BatchDocumentResult",
      "type": "object"
    },
    "BatchReportSummary": {
      "properties": {
        "failed_count": {
          "default": 0,
          "title": "Failed Count",
          "type": "integer"
        },
        "partial_success_count": {
          "default": 0,
          "title": "Partial Success Count",
          "type": "integer"
        },
        "skipped_count": {
          "default": 0,
          "title": "Skipped Count",
          "type": "integer"
        },
        "success_count": {
          "default": 0,
          "title": "Success Count",
          "type": "integer"
        },
        "total_documents": {
          "default": 0,
          "title": "Total Documents",
          "type": "integer"
        }
      },
      "title": "BatchReportSummary",
      "type": "object"
    }
  },
  "properties": {
    "documents": {
      "items": {
        "$ref": "#/$defs/BatchDocumentResult"
      },
      "title": "Documents",
      "type": "array"
    },
    "input_dir": {
      "title": "Input Dir",
      "type": "string"
    },
    "output_dir": {
      "title": "Output Dir",
      "type": "string"
    },
    "pdf_files": {
      "items": {
        "type": "string"
      },
      "title": "Pdf Files",
      "type": "array"
    },
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "summary": {
      "$ref": "#/$defs/BatchReportSummary"
    }
  },
  "required": [
    "input_dir",
    "output_dir"
  ],
  "title": "BatchReport",
  "type": "object"
}
